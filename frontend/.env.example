# Local dev
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# --- Production (frontend Vercel project) — pick ONE approach ---

# A) Direct backend URL — must be the *API* host (not the marketing / Next.js site).
#    Use …/api at the end, or only the origin (https://your-api.vercel.app) — /api is added automatically.
# NEXT_PUBLIC_API_URL=https://your-backend.vercel.app/api

# B) Same domain / rewrites: browser uses yourdremcar.vercel.app for /api AND /uploads (required for /uploads/* images)
# BACKEND_ORIGIN=https://your-backend.vercel.app
# NEXT_PUBLIC_API_URL=/api
# NEXT_PUBLIC_SITE_ORIGIN=https://your-frontend.vercel.app
#
# Images: if cars use /uploads URLs, set ONE of these so the browser + SSR resolve the right host:
# NEXT_PUBLIC_SITE_ORIGIN=https://your-frontend.vercel.app   (with BACKEND_ORIGIN rewrites for /uploads)
# — or point uploads at the API deployment directly:
# NEXT_PUBLIC_UPLOADS_ORIGIN=https://your-backend.vercel.app
# (alias) NEXT_PUBLIC_BACKEND_ORIGIN=https://your-backend.vercel.app

# Deploy uploads without server 403: Cloudinary → Settings → Upload → Add upload preset (Unsigned), folder car-sells.
# Same cloud name as backend CLOUDINARY_CLOUD_NAME:
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_preset_name
