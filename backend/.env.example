# Public URL of *this* Express / serverless deployment (no trailing slash) — NOT the Next.js marketing site.
# Example: https://car-api-xxxxx.vercel.app  (same project as this backend). Used so /uploads links in JSON
# point at the server that actually serves express.static, and to fix DB rows that wrongly used the frontend domain.
# On Vercel, VERCEL_URL is usually enough; set PUBLIC_BASE_URL if you use a custom domain for the API.

FRONTEND_URL=http://localhost:3000
CLOUDINARY_CLOUD_NAME=dwdux0nq6
CLOUDINARY_API_KEY=611538333324275
CLOUDINARY_API_SECRET=R-BcksG3fxEjKhgAqNomdvyPAlk

# If you ever used CLOUDINARY_URL on Vercel, delete it when using the three vars above (403 otherwise).
# Optional single line only (never set both URL and the three vars with different credentials):
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# After deploy, verify: GET https://your-backend/api/health/cloudinary → auth ok
#
# Vercel: add Blob (Storage → Blob → connect store → copy Read/Write token). On serverless, uploads try Blob FIRST.
# BLOB_READ_WRITE_TOKEN=
#
# Recommended for Vercel: create an Unsigned upload preset (Console → Upload → presets) for folder "car-sells",
# then set NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME + NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET on the frontend so images
# upload from the browser (no server secret needed for the upload request).
# Local dev: false = save under ./uploads. On Vercel/Lambda, Cloudinary is used automatically when CLOUDINARY_* are set (disk is read-only — no ./uploads).
# Set true to force Cloudinary even on a normal Node server.
CAR_USE_CLOUDINARY=false

# Happy client photos (admin): default folder is ../frontend/public/images/happy-clients relative to backend/src.
# Set an absolute path on your server if the repo layout differs.
# HAPPY_CLIENTS_IMAGES_DIR=
