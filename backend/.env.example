PORT=5000
MONGODB_URI=mongodb+srv://car123:car123@cluster0.18pyv83.mongodb.net/?appName=Cluster0

# Public URL of this API (no trailing slash). Used for /uploads image URLs and rewriting old localhost imageUrl in JSON.
# On Vercel, VERCEL_URL is set automatically; override with PUBLIC_BASE_URL if you use a custom domain.
# PUBLIC_BASE_URL=https://your-backend.vercel.app

# CORS: leave unset = allow any frontend (local + Vercel + preview URLs).
# Only set to restrict: CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
# Do NOT set old FRONTEND_URL=http://localhost:3000 alone on Vercel — it breaks production CORS.
# Use these three from Cloudinary → Settings → API Keys (same product). Do not mix accounts.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# If you ever used CLOUDINARY_URL on Vercel, delete it when using the three vars above (403 otherwise).
# Optional single line only (never set both URL and the three vars with different credentials):
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# After deploy, verify: GET https://your-backend/api/health/cloudinary → auth ok
# Local dev: false = save under ./uploads. On Vercel/Lambda, Cloudinary is used automatically when CLOUDINARY_* are set (disk is read-only — no ./uploads).
# Set true to force Cloudinary even on a normal Node server.
CAR_USE_CLOUDINARY=false
