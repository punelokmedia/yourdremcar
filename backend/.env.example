PORT=5000
MONGODB_URI=mongodb+srv://car123:car123@cluster0.18pyv83.mongodb.net/?appName=Cluster0

# Optional. Leave empty or use * to allow any origin (easiest for Vercel + local).
# Or comma-separated: http://localhost:3000,https://your-app.vercel.app
# If set to ONLY localhost, production frontend will get "Failed to fetch" (CORS).
FRONTEND_URL=
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Set to true only when Cloudinary keys work. Default is fast local /uploads storage (no Cloudinary round-trip).
# Required true on Vercel (serverless disk is ephemeral — uploads do not persist).
CAR_USE_CLOUDINARY=false
