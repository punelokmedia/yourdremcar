PORT=5000
MONGODB_URI=mongodb+srv://car123:car123@cluster0.18pyv83.mongodb.net/?appName=Cluster0

# Local: http://localhost:3000 | Vercel: https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:3000
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Set to true only when Cloudinary keys work. Default is fast local /uploads storage (no Cloudinary round-trip).
# Required true on Vercel (serverless disk is ephemeral — uploads do not persist).
CAR_USE_CLOUDINARY=false
